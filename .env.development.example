# Exemplo de ambiente para desenvolvimento/local
# Uso: docker compose --env-file .env -f docker-compose-dev.yml up -d

# PORTAS
PORT_MACHINE_BACKEND=3001
PORT_MACHINE_FRONTEND=3000
PORT_MACHINE_DB=5432

# POSTGRES
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appdb

# Conexao do Prisma/Nest via rede interna do Docker
DATABASE_URL=postgresql://postgres:postgres@postgres-db:5432/appdb

# BACKEND
NODE_ENV=development
SECRET_KEY=troque_por_uma_chave_segura_com_32_caracteres_ou_mais
# Para multiplos dominios, separar por virgula (ex: http://localhost:3000,https://app.exemplo.com)
FRONTEND_URL=http://localhost:3000
# O email admin inicial é admin@edutrace.com; coloque a senha aqui
ADMIN_PASSWORD=troque_esta_senha

# FRONTEND
# URL principal usada em runtime pelo front
API_URL=http://localhost:3001
# Fallback legado usado apenas se API_URL nao estiver disponivel, recomendado deixar igual a API_URL
NEXT_PUBLIC_API_EDU_TRACE=http://localhost:3001
# Exemplo de ambiente para producao
# Uso: docker compose --env-file .env.production -f docker-compose-prod.yml up -d

# PORTAS
PORT_MACHINE_BACKEND=3001
PORT_MACHINE_FRONTEND=3000
PORT_MACHINE_DB=5432

# POSTGRES
POSTGRES_USER=pe_estudantes
POSTGRES_PASSWORD=<DEFINA_UMA_SENHA_FORTE_POSTGRES>
POSTGRES_DB=pe_estudantes_db

# Conexao do Prisma/Nest via rede interna do Docker
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres-db:5432/${POSTGRES_DB}

# BACKEND
NODE_ENV=production
SECRET_KEY=troque_por_uma_chave_segura_com_32_caracteres_ou_mais
# Para multiplos dominios, separar por virgula (ex: https://front.edutrace.site,https://app.exemplo.com)
FRONTEND_URL=url_do_frontend_producao
# O email admin inicial é admin@edutrace.com; coloque a senha aqui
ADMIN_PASSWORD=troque_esta_senha

# FRONTEND
# URL principal usada em runtime pelo front
API_URL=url_da_api_producao
# Fallback legado usado apenas se API_URL nao estiver disponivel (recomendado deixar igual a API_URL)
NEXT_PUBLIC_API_EDU_TRACE=url_da_api_producao

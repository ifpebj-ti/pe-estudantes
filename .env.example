# FRONTEND
PORT_MACHINE_FRONTEND=3000

# API principal usada em runtime pelo front via runtime-config.js.
# Pode ser alterada sem rebuild, recriando apenas o container next-app.
API_URL=http://localhost:3001

# Fallback legado usado apenas se API_URL não estiver disponível.
# Deixar igual a API_URL para evitar chamadas para endpoint diferente.
NEXT_PUBLIC_API_EDU_TRACE=http://localhost:3001

# BACKEND
PORT_MACHINE_BACKEND=3001
DATABASE_URL=postgresql://postgres:postgres@postgres-db:5432/appdb
NODE_ENV=production
SECRET_KEY=supersecret123

# POSTGRES
PORT_MACHINE_DB=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appdb
